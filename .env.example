# Copy to .env and fill in your values. Do not commit .env.

# Mixpanel (optional, OFF by default): set SEND_TO_MIXPANEL=true to enable
MIXPANEL_TOKEN=
SEND_TO_MIXPANEL=false

# Person ID cache: match new tracker IDs to previously seen people (true/false)
USE_PERSON_CACHE=true
# Supervision: zone, people in zone, time in zone, heatmap (true/false)
USE_SUPERVISION=true
# Seconds to wait after person leaves zone before sending dwell event (default 5)
DWELL_LEAVE_BUFFER_SEC=5
